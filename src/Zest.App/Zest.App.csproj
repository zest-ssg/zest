<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- .NET Tool packaging
         Installed via:  dotnet tool install -g zest
         Invoked via:    zest <command>
         PackAsTool places the output under the tool manifest layout
         so `dotnet tool install` works against the produced .nupkg.
         ToolCommandName=zest keeps the CLI command name short.
         PackageId=zest matches the .NET tool naming convention
         (lowercase, like dotnet-ef / powershell / dotnet-outdated). -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>zest</ToolCommandName>
    <PackageId>zest</PackageId>
    <IsPackable>true</IsPackable>

    <!-- Framework-dependent deployment (FSI needs assemblies on disk).
         No RID is set so the tool is platform-neutral and runs on any
         .NET 10 runtime (win/linux/osx). The previous win-x64 hard-coding
         blocked `dotnet tool install` on non-Windows hosts. -->
    <PublishSingleFile>false</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <AssemblyName>zest</AssemblyName>
    <DebugType>embedded</DebugType>

    <!-- Publish trimming: exclude unused files -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <TrimMode>partial</TrimMode>

    <!-- App icon -->
    <ApplicationIcon>..\..\zest.ico</ApplicationIcon>

    <!-- Pack README + icon into the .nupkg so nuget.org shows them.
         The files live at repo root; PackFolderInclude keeps them
         at the package root for NuGet's metadata conventions. -->
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>zest.png</PackageIcon>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Zest.Engine\Zest.Engine.fsproj" />
    <ProjectReference Include="..\Zest.Infra\Zest.Infra.csproj" />
    <ProjectReference Include="..\Zest.Dsl\Zest.Dsl.fsproj" />
  </ItemGroup>

  <!-- zest.toml holds CLI branding/help text. Embed it as a resource so
       the tool works immediately after `dotnet tool install` without
       needing to locate the file on disk. HelpRenderer falls back to
       the file-system path during local development. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\zest.toml">
      <LogicalName>zest.toml</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Bundled `zest init` default starter site (mirrors the zest.toml
       embedding above). LogicalName preserves the relative path (using
       backslashes) so InitController can reconstruct file paths at runtime,
       keeping the starter self-contained after `dotnet tool install`.
       `Starters` holds the starter-project definitions copied out by init
       (the default blog preset); it is NOT the runtime template engine
       (which lives in Zest.Engine/Template). -->
  <ItemGroup>
    <None Remove="Starters\**\*" />
    <EmbeddedResource Include="Starters\_config.toml">
      <LogicalName>Zest.App.Starters._config.toml</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\_init.zest.fsx">
      <LogicalName>Zest.App.Starters._init.zest.fsx</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\README.md">
      <LogicalName>Zest.App.Starters.README.md</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\_layouts\default.html">
      <LogicalName>Zest.App.Starters._layouts\default.html</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\_layouts\post.html">
      <LogicalName>Zest.App.Starters._layouts\post.html</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\_includes\header.html">
      <LogicalName>Zest.App.Starters._includes\header.html</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\_includes\footer.html">
      <LogicalName>Zest.App.Starters._includes\footer.html</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\assets\css\main.zcss">
      <LogicalName>Zest.App.Starters.assets\css\main.zcss</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\content\index.zest.fsx">
      <LogicalName>Zest.App.Starters.content\index.zest.fsx</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\content\about.zest.fsx">
      <LogicalName>Zest.App.Starters.content\about.zest.fsx</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\content\posts\index.zest.fsx">
      <LogicalName>Zest.App.Starters.content\posts\index.zest.fsx</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\content\posts\welcome-to-zest.zest.fsx">
      <LogicalName>Zest.App.Starters.content\posts\welcome-to-zest.zest.fsx</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Starters\content\posts\building-sites-with-fsharp.zest.fsx">
      <LogicalName>Zest.App.Starters.content\posts\building-sites-with-fsharp.zest.fsx</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Package icon + README at the nupkg root (NuGet metadata convention). -->
  <ItemGroup>
    <None Include="..\..\zest.png" Pack="true" PackagePath="\" />
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

  <!-- Exclude unused files from publish output -->
  <ItemGroup>
    <!-- Remove satellite resource assemblies (empty locale folders) -->
    <SatelliteAssemblies Remove="@(SatelliteAssemblies)" />
    <!-- Exclude XML documentation files -->
    <None Remove="**\*.xml" />
    <None Remove="**\*.pdb" />
    <!-- Exclude source files from publish -->
    <None Remove="**\*.fs" />
    <None Remove="**\*.fsi" />
    <None Remove="**\*.fsproj" />
    <None Remove="**\*.cs" />
    <None Remove="**\*.csproj" />
  </ItemGroup>

</Project>
