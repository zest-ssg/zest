<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Single-file publish -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <AssemblyName>zest</AssemblyName>
    <DebugType>embedded</DebugType>

    <!-- App info -->
    <Copyright>Apache 2.0 License</Copyright>
    <Description>Zest SSG — Zenith Efficient Static Toolkit</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Zest.Engine\Zest.Engine.fsproj" />
    <ProjectReference Include="..\Zest.Infra\Zest.Infra.csproj" />
  </ItemGroup>

</Project>
