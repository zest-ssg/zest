<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- Framework-dependent deployment (FSI needs assemblies on disk) -->
    <PublishSingleFile>false</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <AssemblyName>zest</AssemblyName>
    <DebugType>embedded</DebugType>

    <!-- Strip satellite resource assemblies and debug symbols from publish output -->
    <SatelliteResourceLanguages>none</SatelliteResourceLanguages>
    <DebugSymbols>false</DebugSymbols>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>

    <!-- App info -->
    <Copyright>Apache 2.0 License</Copyright>
    <Description>Zest SSG — Zenith Efficient Static Toolkit</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Zest.Engine\Zest.Engine.fsproj" />
    <ProjectReference Include="..\Zest.Infra\Zest.Infra.csproj" />
  </ItemGroup>

</Project>
